# profitOS SaaS v3.0 — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha todos os valores

# ─── BANCO DE DADOS ────────────────────────────────────────────────────────────
# Recomendado: Neon (neon.tech) — Plano gratuito, região São Paulo
# Pooled (com pgbouncer) — para conexões da aplicação
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/profitos?sslmode=require&pgbouncer=true&connect_timeout=15"
# Direct (sem pgbouncer) — para migrations Prisma
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/profitos?sslmode=require"

# ─── NEXTAUTH ──────────────────────────────────────────────────────────────────
# Gere um secret seguro: openssl rand -base64 32
NEXTAUTH_SECRET="substitua-por-string-aleatoria-minimo-32-chars"
# Local: http://localhost:3000 | Produção: https://seudominio.com.br
NEXTAUTH_URL="http://localhost:3000"

# ─── GOOGLE OAUTH ──────────────────────────────────────────────────────────────
# 1. Acesse: https://console.cloud.google.com
# 2. Crie projeto → APIs & Services → Credentials → Create OAuth 2.0 Client ID
# 3. Tipo: Web Application
# 4. Redirect URI autorizado:
#    Local:     http://localhost:3000/api/auth/callback/google
#    Produção:  https://seudominio.com.br/api/auth/callback/google
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxx"

# ─── APP ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="profitOS"

# ─── EMAIL ─────────────────────────────────────────────────────────────────────
# Recomendado: Resend (resend.com) — 3.000 e-mails/mês gratuito
# Usado para: convites de usuários, recuperação de senha
RESEND_API_KEY=""
EMAIL_FROM="noreply@seudominio.com.br"

# ─── CRON ──────────────────────────────────────────────────────────────────────
# Protege o endpoint /api/cron/runrunit-sync (sync diário RunRun.it 7h BRT)
# Gere: openssl rand -hex 32
CRON_SECRET="substitua-por-hex-aleatorio-64-chars"
